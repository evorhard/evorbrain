# EditorConfig is awesome: https://EditorConfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown files
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 80

# TypeScript and JavaScript
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
quote_type = single

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Rust files
[*.rs]
indent_size = 4

# TOML files
[*.toml]
indent_size = 4

# Makefile
[Makefile]
indent_style = tab

# Ignore generated files
[{*.min.js,*.min.css,dist/**,build/**}]
indent_style = ignore
indent_size = ignore