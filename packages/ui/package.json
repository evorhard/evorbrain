{
  "name": "@evorbrain/ui",
  "version": "0.1.0",
  "description": "Shared UI components and design system for EvorBrain",
  "author": "Edvard Evorhard <edvard@evorhard.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "import": "./src/styles/index.css"
    }
  },
  "files": [
    "dist/**/*",
    "src/styles/**/*.css"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc && pnpm build:css",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css",
    "test": "vitest --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "analyze": "pnpm run lint && pnpm run typecheck && pnpm run format:check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@evorbrain/types": "workspace:*",
    "@evorbrain/core": "workspace:*",
    "clsx": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^7.6.0",
    "@storybook/react": "^7.6.0",
    "@storybook/react-vite": "^7.6.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "storybook": "^7.6.0",
    "tailwindcss": "^3.3.6",
    "vitest": "^3.2.4"
  }
}
