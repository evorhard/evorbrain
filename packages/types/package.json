{
  "name": "@evorbrain/types",
  "version": "0.1.0",
  "description": "Shared TypeScript type definitions for EvorBrain",
  "author": "Edvard Evorhard <edvard@evorhard.com>",
  "license": "Apache-2.0",
  "type": "module",
  "types": "./src/index.d.ts",
  "files": [
    "src/**/*.d.ts"
  ],
  "scripts": {
    "test": "echo \"No tests for types package\"",
    "test:ci": "echo \"No tests for types package\"",
    "test:coverage": "echo \"No tests for types package\"",
    "lint": "eslint . --ext .ts,.d.ts",
    "format": "prettier --write \"src/**/*.d.ts\"",
    "format:check": "prettier --check \"src/**/*.d.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "analyze": "pnpm run lint && pnpm run typecheck && pnpm run format:check",
    "clean": "rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^24.1.0"
  }
}
