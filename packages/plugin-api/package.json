{
  "name": "@evorbrain/plugin-api",
  "version": "0.1.0",
  "description": "Plugin API definitions and interfaces for EvorBrain",
  "author": "Edvard Evorhard <edvard@evorhard.com>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "analyze": "pnpm run lint && pnpm run typecheck && pnpm run format:check",
    "docs": "typedoc --out docs src/index.ts",
    "clean": "rm -rf dist node_modules .turbo docs"
  },
  "dependencies": {
    "@evorbrain/types": "workspace:*",
    "@evorbrain/core": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "typedoc": "^0.25.4",
    "vitest": "^3.2.4"
  }
}
