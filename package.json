{
  "name": "evorbrain",
  "version": "0.1.0",
  "private": true,
  "description": "An offline-first personal knowledge management system built with Tauri, React, and TypeScript",
  "author": "Edvard Evorhard <edvard@evorhard.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/evorhard/evorbrain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evorhard/evorbrain.git"
  },
  "bugs": {
    "url": "https://github.com/evorhard/evorbrain/issues"
  },
  "keywords": [
    "knowledge-management",
    "gtd",
    "productivity",
    "tauri",
    "react",
    "typescript",
    "offline-first"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "pnpm --filter \"@evorbrain/*\" run dev",
    "build": "pnpm --filter \"@evorbrain/*\" run build",
    "test": "pnpm --filter \"@evorbrain/*\" run test",
    "lint": "pnpm --filter \"@evorbrain/*\" run lint",
    "format": "pnpm --filter \"@evorbrain/*\" run format",
    "typecheck": "pnpm --filter \"@evorbrain/*\" run typecheck",
    "clean": "pnpm --filter \"@evorbrain/*\" run clean && rm -rf node_modules .pnpm-store",
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}