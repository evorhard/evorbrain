{
  "$schema": "https://schema.tauri.app/config/v2",
  "productName": "EvorBrain",
  "version": "0.1.0",
  "identifier": "com.evorbrain.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2024 Edvard Evorhard",
    "category": "Productivity",
    "shortDescription": "Offline-first personal knowledge management",
    "longDescription": "EvorBrain is an offline-first personal knowledge management system that helps you organize your thoughts, tasks, and projects using a hierarchical structure.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "windows": [
      {
        "title": "EvorBrain",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "contentProtected": false,
        "hiddenTitle": false,
        "acceptFirstMouse": false,
        "tabbingIdentifier": null
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true
    },
    "macOSPrivateApi": true
  },
  "plugins": {}
}
