{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "file-scope",
  "description": "File system scope restrictions for EvorBrain",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOCAL/**"
        },
        {
          "path": "$DOCUMENT/EvorBrain/**"
        },
        {
          "path": "$HOME/EvorBrain/**"
        }
      ],
      "deny": [
        {
          "path": "$HOME/.ssh/**"
        },
        {
          "path": "$HOME/.gnupg/**"
        },
        {
          "path": "**/node_modules/**"
        },
        {
          "path": "**/.git/**"
        }
      ]
    }
  ]
}
