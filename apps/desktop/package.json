{
  "name": "@evorbrain/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "EvorBrain desktop application built with Tauri",
  "author": "Edvard Evorhard <edvard@evorhard.com>",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "build": "pnpm run build:web",
    "build:web": "tsc && vite build",
    "build:tauri": "pnpm run build:web && tauri build",
    "build:debug": "pnpm run build:web && tauri build --debug",
    "build:windows": "pnpm run build:web && tauri build --target x86_64-pc-windows-msvc",
    "build:mac": "pnpm run build:web && tauri build --target universal-apple-darwin",
    "build:linux": "pnpm run build:web && tauri build --target x86_64-unknown-linux-gnu",
    "build:all": "pnpm run build:web && tauri build --target all",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo src-tauri/target",
    "clean:deep": "pnpm run clean && rm -rf pnpm-lock.yaml",
    "analyze": "vite build --mode analyze",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "check:fix": "pnpm run typecheck && pnpm run lint:fix && pnpm run format",
    "rust:check": "cd src-tauri && cargo check",
    "rust:clippy": "cd src-tauri && cargo clippy -- -D warnings",
    "rust:fmt": "cd src-tauri && cargo fmt",
    "rust:fmt:check": "cd src-tauri && cargo fmt -- --check",
    "rust:test": "cd src-tauri && cargo test",
    "preinstall": "node -e \"if(process.env.npm_execpath.indexOf('pnpm') === -1) throw new Error('Please use pnpm to install dependencies')\""
  },
  "dependencies": {
    "@evorbrain/core": "workspace:*",
    "@evorbrain/types": "workspace:*",
    "@evorbrain/ui": "workspace:*",
    "@mantine/core": "^7.3.0",
    "@mantine/hooks": "^7.3.0",
    "@tauri-apps/api": "^2.0.0-alpha.11",
    "jotai": "^2.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0-alpha.17",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vitest": "^3.2.4"
  }
}
